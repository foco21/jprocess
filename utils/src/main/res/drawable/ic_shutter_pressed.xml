<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer ring uses Material You primary color -->
    <item>
        <shape android:shape="oval">
            <stroke android:width="3dp" android:color="?attr/colorPrimary"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
    <!-- Inner fill slightly compressed on press -->
    <item
        android:left="13dp"
        android:right="13dp"
        android:top="13dp"
        android:bottom="13dp">
        <shape android:shape="oval">
            <solid android:color="?attr/colorOnPrimaryContainer"/>
        </shape>
    </item>
</layer-list>
