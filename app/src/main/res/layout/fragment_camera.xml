<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera viewfinder — pinned to the top; 3:4 preview. -->
    <com.reilandeubank.unprocess.utils.AutoFitSurfaceView
        android:id="@+id/view_finder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Rule-of-thirds grid overlay -->
    <com.reilandeubank.unprocess.GridOverlayView
        android:id="@+id/grid_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Capture flash overlay -->
    <View
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Settings button — top left -->
    <ImageButton
        android:id="@+id/settings_button"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="48dp"
        android:src="@drawable/ic_settings"
        android:background="@drawable/scrim_circle_background"
        android:padding="10dp"
        android:contentDescription="Settings"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Timer button — top center -->
    <ImageButton
        android:id="@+id/timer_button"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="48dp"
        android:src="@drawable/ic_timer"
        android:background="@drawable/scrim_circle_background"
        android:padding="10dp"
        android:alpha="0.5"
        android:contentDescription="Self-timer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Timer mode label — below timer button -->
    <TextView
        android:id="@+id/timer_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/timer_button"
        app:layout_constraintStart_toStartOf="@id/timer_button"
        app:layout_constraintEnd_toEndOf="@id/timer_button" />

    <!-- Countdown text — center screen, shown during self-timer -->
    <TextView
        android:id="@+id/countdown_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="120sp"
        android:textStyle="bold"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="8"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Zoom level indicator — shown briefly during pinch-to-zoom -->
    <TextView
        android:id="@+id/zoom_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/notification_badge"
        android:textColor="?attr/colorOnSecondaryContainer"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:elevation="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/view_finder"
        app:layout_constraintBottom_toBottomOf="@id/view_finder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Focus ring — repositioned in code on tap -->
    <View
        android:id="@+id/focus_ring"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/focus_ring"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Photo saved notification — top center floating badge -->
    <TextView
        android:id="@+id/notification_banner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/notification_badge"
        android:textColor="?attr/colorOnSecondaryContainer"
        android:text="Photo saved"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:textSize="14sp"
        android:letterSpacing="0.01"
        android:elevation="8dp"
        android:visibility="gone"
        android:layout_marginTop="56dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ───────── Unified Material You control deck ─────────
         A rounded-top surface that overlaps the bottom of the preview by 28dp (its rounded
         corners reveal the preview behind them) and holds every control top-to-bottom.
         Background (rounded top + dynamic surface-container-highest) + elevation set in code. -->
    <LinearLayout
        android:id="@+id/bottom_deck"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:layout_marginTop="-28dp"
        android:paddingTop="28dp"
        android:elevation="16dp"
        app:layout_constraintTop_toBottomOf="@id/view_finder"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Lens selector chips -->
        <HorizontalScrollView
            android:id="@+id/lens_scroll_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="6dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/lens_chip_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                app:chipSpacingHorizontal="10dp"
                app:singleLine="true"
                app:singleSelection="true"
                app:selectionRequired="true" />

        </HorizontalScrollView>

        <!-- PRO read-outs — ISO, shutter, WB, EV, focus (RAW only) -->
        <HorizontalScrollView
            android:id="@+id/pro_controls_scroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:visibility="gone"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="14dp"
            android:paddingBottom="2dp"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:baselineAligned="false">

                <LinearLayout
                    android:id="@+id/pro_iso"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/pro_tile_outline"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ISO"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="9sp"
                        android:letterSpacing="0.06" />
                    <TextView
                        android:id="@+id/pro_iso_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AUTO"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/pro_shutter"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/pro_tile_outline"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SS"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="9sp"
                        android:letterSpacing="0.06" />
                    <TextView
                        android:id="@+id/pro_shutter_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AUTO"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/pro_wb"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/pro_tile_outline"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WB"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="9sp"
                        android:letterSpacing="0.06" />
                    <TextView
                        android:id="@+id/pro_wb_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AUTO"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/pro_ev"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/pro_tile_outline"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EV"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="9sp"
                        android:letterSpacing="0.06" />
                    <TextView
                        android:id="@+id/pro_ev_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/pro_focus"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/pro_tile_outline">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MF"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="9sp"
                        android:letterSpacing="0.06" />
                    <TextView
                        android:id="@+id/pro_focus_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AUTO"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Zoom switcher -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/zoom_toggle_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/zoom_1x"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:textSize="15sp"
                android:text="1x" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/zoom_2x"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:textSize="15sp"
                android:text="2x" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Bottom control row: gallery · shutter · format -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="36dp"
            android:paddingEnd="36dp">

            <!-- Gallery thumbnail -->
            <ImageButton
                android:id="@+id/gallery_button"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/gallery_thumb_background"
                android:src="@drawable/ic_photo"
                android:tint="?attr/colorOnSurfaceVariant"
                android:padding="12dp"
                android:scaleType="centerCrop"
                android:contentDescription="Gallery" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Shutter / Capture button -->
            <ImageButton
                android:id="@+id/capture_button"
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:background="@drawable/ic_shutter"
                android:contentDescription="Capture" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Format quick-switch -->
            <LinearLayout
                android:id="@+id/format_button"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/format_btn_bg"
                android:backgroundTint="?attr/colorSecondaryContainer"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Switch format">
                <TextView
                    android:id="@+id/format_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JPG"
                    android:textColor="?attr/colorOnSecondaryContainer"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
